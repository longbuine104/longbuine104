 function FUNCTIONSmodule.emoteDetailPage(emote, origin, alternateAnimID, playFunc, shouldTransformOriginParam)
 itemDetailFrame.Item.Details.ItemName.Text = emote\["name"\]
 if emote\["description"\] then
